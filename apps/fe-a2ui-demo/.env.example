# A2UI Demo Frontend - Local Development
#
# Copy this file to .env.local and fill in values:
#   cp .env.example .env.local
#
# Vite automatically loads .env.local for local overrides.
# The FE proxies /a2ui requests to the BE, so no API URL is needed
# when both run on their default ports.

# ── Backend Connection ────────────────────────────────────────
# The Vite dev server proxies /a2ui → http://localhost:5001
# Only change this if your BE runs on a different port.
# VITE_A2UI_BACKEND_URL=http://localhost:5001