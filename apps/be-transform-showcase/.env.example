# A2UI Showcase Host - Local Development
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The BE app uses spring-dotenv to load .env automatically.

# ── LLM Provider ──────────────────────────────────────────────
# Required: Your OpenAI-compatible API key
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Override the API base URL (use Groq, Azure, etc.)
# OPENAI_BASE_URL=https://api.openai.com

# Optional: Override the model
# OPENAI_MODEL=gpt-4.1-nano

# ── A2UI Runtime ──────────────────────────────────────────────
# A2UI runtime deterministic policy defaults (safe to leave as-is)
# A2UI_RUNTIME_TEMPERATURE=0.0
# A2UI_RUNTIME_TOP_P=1.0
# A2UI_RUNTIME_CAP_TEMPERATURE=true
# A2UI_RUNTIME_CAP_TOP_P=true
# A2UI_RUNTIME_CAP_SEED=true
# A2UI_RUNTIME_CAP_MAX_TOKENS=true
# A2UI_RUNTIME_CAP_MAX_COMPLETION_TOKENS=true
# A2UI_RUNTIME_ADVISORS_ENABLED=true
# A2UI_RUNTIME_ADVISORS_FAIL_FAST=true
# A2UI_RUNTIME_ADVISORS_DETERMINISTIC_OPTIONS_ENABLED=true
# A2UI_RUNTIME_ADVISORS_RUNTIME_VALIDATION_ENABLED=true